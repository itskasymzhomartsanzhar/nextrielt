DJANGO_DEBUG=0
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend,estate.swiftagents.ru

# Frontend origins allowed to call backend API from browser.
CORS_ALLOWED_ORIGINS=https://estate.swiftagents.ru,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3130,http://127.0.0.1:3130

# Origins trusted for CSRF checks on non-API POST endpoints (admin/forms).
DJANGO_CSRF_TRUSTED_ORIGINS=https://estate.swiftagents.ru,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3130,http://127.0.0.1:3130,http://localhost:8000,http://127.0.0.1:8000

# Keep these enabled when Django is behind reverse proxy with TLS termination.
DJANGO_USE_X_FORWARDED_PROTO=1
DJANGO_USE_X_FORWARDED_HOST=1
